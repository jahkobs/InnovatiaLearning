{
  "name": "innovatia-learning-platform",
  "version": "1.0.0",
  "description": "Innovatia Digital Learning & Curriculum Management Platform - Year 1 interactive desktop application",
  "main": "electron/main.js",
  "author": "Innovatia",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "icon": "node scripts/make-icon.js",
    "start": "node scripts/make-icon.js && electron .",
    "dist": "node scripts/make-icon.js && electron-builder --win",
    "dist:portable": "node scripts/make-icon.js && electron-builder --win portable",
    "pack": "node scripts/make-icon.js && electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "org.innovatia.learningplatform",
    "productName": "Innovatia Learning",
    "copyright": "Copyright © 2026 Innovatia",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Innovatia-Learning-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Innovatia Learning",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
